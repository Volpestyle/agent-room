{
  "name": "@agentroom/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "agentroom-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agentroom/config": "workspace:*",
    "@agentroom/core": "workspace:*",
    "@agentroom/runtime-fake": "workspace:*",
    "@agentroom/runtime-herdr": "workspace:*",
    "@agentroom/runtime-tmux": "workspace:*",
    "@agentroom/runtime-zellij": "workspace:*",
    "@agentroom/storage-jsonl": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@agentroom/core": [
        "packages/core/src/index.ts"
      ],
      "@agentroom/config": [
        "packages/config/src/index.ts"
      ],
      "@agentroom/storage-jsonl": [
        "packages/storage-jsonl/src/index.ts"
      ],
      "@agentroom/runtime-fake": [
        "packages/runtime-fake/src/index.ts"
      ],
      "@agentroom/runtime-herdr": [
        "packages/runtime-herdr/src/index.ts"
      ],
      "@agentroom/runtime-tmux": [
        "packages/runtime-tmux/src/index.ts"
      ],
      "@agentroom/runtime-zellij": [
        "packages/runtime-zellij/src/index.ts"
      ],
      "@agentroom/tui": [
        "apps/tui/src/index.ts"
      ],
      "@agentroom/chat-discord": [
        "packages/integrations/chat-discord/src/index.ts"
      ],
      "@agentroom/diorama-core": [
        "packages/diorama-core/src/index.ts"
      ],
      "@agentroom/diorama-town": [
        "packages/diorama-town/src/index.ts"
      ],
      "@agentroom/diorama-pixi": [
        "packages/diorama-pixi/src/index.ts"
      ]
    }
  }
}
